# Gemini APIキー（必須）。https://aistudio.google.com/apikey で取得できます。
# 未設定の場合はサイドバーに表示される入力欄から直接入力できます。
GEMINI_API_KEY=

# サインイン用パスワード（任意）。設定するとアプリ起動時にパスワード入力が求められます。
# 空のままにすると誰でもアクセスできます。
APP_PASSWORD=

# Googleドライブ連携（任意）。両方設定すると「ドキュメントライブラリ」に
# 指定フォルダ内のPDF一覧が表示され、選んで読み込めるようになります。
#
# 1. Google Cloud Console でプロジェクトを作成し、Drive API を有効化
# 2. サービスアカウントを作成し、JSONキーをダウンロード
# 3. そのサービスアカウントのメールアドレスを、対象のDriveフォルダに
#    「閲覧者」として共有
# 4. `jq -c . service_account.json` で1行化してここに貼り付け
GOOGLE_SERVICE_ACCOUNT_JSON=

# 上記フォルダのID（フォルダのURLの https://drive.google.com/drive/folders/<この部分> ）
DRIVE_FOLDER_ID=
